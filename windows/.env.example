# ============================================================
# استوديو بوت تيليغرام — إعدادات البيئة
# انسخ هذا الملف وسمّه .env ثم عدّل القيم
# ============================================================

# المنفذ الذي يعمل عليه الخادم (افتراضي 3000)
PORT=3000

# بيئة التشغيل
NODE_ENV=production

# ─── البروكسي (اختياري) ───────────────────────────────────
# إذا كنت تحتاج بروكسي للوصول إلى تيليغرام أو Gemini:
# HTTPS_PROXY=http://user:password@proxy-host:port
# HTTP_PROXY=http://user:password@proxy-host:port
# SOCKS5_PROXY=socks5://user:password@proxy-host:port
# ALL_PROXY=http://proxy-host:port
